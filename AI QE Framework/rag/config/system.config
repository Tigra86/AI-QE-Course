[API]
API_URL 		= http://127.0.0.1:8080/api/predict

S_OUTPUT_FILE 	= reports/semantic_output.json
S_HTML_REPORT 	= reports/semantic_report.html

PM_OUTPUT_FILE 	= reports/partial_match_output.json
PM_HTML_REPORT 	= reports/partial_match_report.html

SENTENCE_INPUT 	= reports/semantic_output.json
SEN_HTML_REPORT = reports/sentence_validation_report.html

STATIC_CSS		= https://alex.academy/ai/static/css/validation.css
STATIC_JS   	= https://alex.academy/ai/static/js/validation.js
STATIC_JS_SEM 	= https://alex.academy/ai/static/js/semantic_filters.js
STATIC_JS_SEN 	= https://alex.academy/ai/static/js/sentence_filter.js

SIMILARITY_THRESHOLD = 0.85
SEMANTIC_THRESHOLD = 0.80

REQUEST_TIMEOUT = 10

EMBED_MODEL 	= all-MiniLM-L6-v2

[RULES]
MIN_TOKENS_WARN = 3
MAX_TOKENS_WARN = 40
MAX_TOKENS_FAIL = 80

[INTENT_THRESHOLDS]
product_specs = 0.45
technical_how_to = 0.45
local_information = 0.45
other = 0.20
government = 0.45
science = 0.45
service = 0.45

[UI]
MODEL = model.pkl
LOG_FILE = log/chat_logs.jsonl

[INFERENCE]
TEMPERATURE = 1.3

[ALIGNMENT]
BLOCKED_KEYWORDS = hack, exploit, illegal, bypass, crack
DISALLOWED_RULES = {"any": ["weapon", "gun", "bomb", "explosive"]}

REFUSAL_MESSAGE = I can't help with that request.
RESTRICTED_MESSAGE = That topic is restricted.

[FUZZY]
threshold = 70

[QA]
collapse_dominance = 0.85
collapse_entropy_floor = 0.35